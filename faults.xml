<?xml version="1.0" encoding="UTF-8"?>
<fault-injection>

    <model>RR_Protocol.smv</model>

    <protocol-type>RR</protocol-type>

    <modules>

        <module name="Client">

            <redundancy count="1"/>

            <faults>


            </faults>

        </module>

        <module name="Server">

            <redundancy count="2"/>

            <faults>
                
                <fault id="stuck_receiving">
                    <type>stuck-at</type>
                    <variable>server_request_state</variable>
                    <value>receiving</value>
                </fault>

                <fault id="stuck_received">
                    <type>stuck-at</type>
                    <variable>server_request_state</variable>
                    <value>received</value>
                </fault>   

            </faults>

        </module>

    </modules>

    <properties>
        <property id="nominal_implies_extended">
            <comment></comment>
            <spec>
                nominal.server.num_requests_received =
                extended.server1.num_requests_received +
                extended.server2.num_requests_received 
            </spec>
        </property>
    </properties>

</fault-injection>