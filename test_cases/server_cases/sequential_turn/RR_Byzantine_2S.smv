-- =========================================================
-- Test case for RR Protocol with the following configuration:
-- * Client's redundancy = 1
-- * Servers's redundancy = 2
-- * Fault type = byzantine
-- * Sequential turn selector
-- =========================================================
MODULE Queue(Q_SIZE, producer_toggle, consumer_toggle)
VAR
    head : 0..3;
    tail : 0..3;
    last_producer_toggle : boolean;  -- last toggle value we saw
    last_consumer_toggle : boolean;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
    init(last_producer_toggle) := FALSE;
    init(last_consumer_toggle) := FALSE;

    next(tail) := case
        (producer_toggle != last_producer_toggle) : (tail + 1) mod Q_SIZE;    -- produce if toggle changed (new request detected)
        TRUE : tail;
    esac;

    next(head) := case
        (consumer_toggle != last_consumer_toggle) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

    next(last_producer_toggle) := case
        (producer_toggle != last_producer_toggle) : producer_toggle;
        TRUE : last_producer_toggle;
    esac;

    next(last_consumer_toggle) := case
        (consumer_toggle != last_consumer_toggle) : consumer_toggle;
        TRUE : last_consumer_toggle;
    esac;

DEFINE
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);



MODULE Client(request_queue, ack_queue)
VAR
    client_request_state : {sending, sent};
    client_ack_state  : {receiving, received};
    request_toggle : boolean;  
    ack_toggle : boolean;    
    ack_received : boolean;
    num_requests_sent : 0..100;    

ASSIGN
    init(client_request_state) := sending;
    init(client_ack_state)  := receiving;
    init(request_toggle) := FALSE;
    init(ack_toggle) := FALSE;
    init(ack_received) := TRUE;
    init(num_requests_sent) := 0;

    next(client_request_state) := case
            client_request_state = sending & request_queue.full : sending;
            client_request_state = sending & !request_queue.full & ack_received : sent;
            client_request_state = sent & !request_queue.full : sending;
            client_request_state = sent & request_queue.full : sent;
            TRUE : client_request_state;
        esac;

    next(client_ack_state) := case
            client_ack_state = receiving & ack_queue.empty : receiving;
            client_ack_state = receiving & !ack_queue.empty : received;
            client_ack_state = received & !ack_queue.empty : receiving;
            client_ack_state = received & ack_queue.empty : received;
            TRUE : client_ack_state;
        esac;

    next(request_toggle) := case
        client_request_state = sending & !request_queue.full & ack_received : !request_toggle;              
        TRUE : request_toggle;                                                      
    esac;

    next(ack_toggle) := case
        client_ack_state = receiving & !ack_queue.empty : !ack_toggle;                   
        TRUE : ack_toggle;                                                      
    esac;

    next(ack_received) := case
        client_request_state = sending & !request_queue.full & ack_received : FALSE;       -- false because a new request has just been sent
        client_ack_state = receiving & !ack_queue.empty : TRUE;          -- true because a new ack has been received
        TRUE : ack_received;           
    esac;

    next(num_requests_sent) := case
        client_request_state = sending & !request_queue.full & ack_received & num_requests_sent < 100 : num_requests_sent + 1;                   
        TRUE : num_requests_sent;                                                    
    esac;



MODULE Server(request_queue, ack_queue)
VAR
    server_request_state : {receiving, received};
    server_ack_state : {sending, sent};
    request_toggle : boolean;  
    ack_toggle : boolean;
    request_received : boolean;
    num_requests_received : 0..100;

ASSIGN
    init(server_request_state) := receiving;
    init(server_ack_state) := sending;
    init(request_toggle) := FALSE;
    init(ack_toggle) := FALSE;
    init(request_received) := FALSE;
    init(num_requests_received) := 0;

    next(server_request_state) :=
        case
            server_request_state = receiving & request_queue.empty : receiving;
            server_request_state = receiving & !request_queue.empty : received;
            server_request_state = received & !request_queue.empty : receiving;
            server_request_state = received & request_queue.empty : received;
            TRUE : server_request_state;
        esac;

    next(server_ack_state) :=
        case
            server_ack_state = sending & ack_queue.full : sending;
            server_ack_state = sending & !ack_queue.full & request_received : sent;
            server_ack_state = sent & !ack_queue.full : sending;
            server_ack_state = sent & ack_queue.full : sent;
            TRUE : server_ack_state;
        esac;

    next(request_toggle) := case
        server_request_state = receiving & !request_queue.empty : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(ack_toggle) := case
        server_ack_state = sending & !ack_queue.full & request_received : !ack_toggle;                   
        TRUE : ack_toggle;                                                    
    esac;

    next(request_received) := case
        server_ack_state = sending & !ack_queue.full & request_received : FALSE;        -- false because a new ack has just been sent
        server_request_state = receiving & !request_queue.empty : TRUE;         -- true because a new request has been received
        TRUE : request_received;     
    esac;

    next(num_requests_received) := case
        server_request_state = receiving & !request_queue.empty & num_requests_received < 100 : num_requests_received + 1;                   
        TRUE : num_requests_received;                                                    
    esac;
    

MODULE Nominal()
DEFINE
    Q_SIZE := 4;
VAR
    client : Client(request_queue, ack_queue);
    server : Server(request_queue, ack_queue);
    request_queue : Queue(Q_SIZE, client.request_toggle, server.request_toggle);
    ack_queue : Queue(Q_SIZE, server.ack_toggle, client.ack_toggle);


MODULE QueueExtended(Q_SIZE, producer_toggles, consumer_toggles)
VAR
    producer_id : array 0..3 of {none, clt0, clt1, clt2, clt3, clt4, clt5, clt6, clt7, clt8, clt9};
    head : 0..3;
    tail : 0..3;
    last_producer_toggle : array 0..9 of boolean;  -- last toggle value we saw
    last_consumer_toggle : array 0..9 of boolean;

    next_producer_turn : 0..9;
    next_consumer_turn : 0..9;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
        init(producer_id[0]) := none;
    init(producer_id[1]) := none;
    init(producer_id[2]) := none;
    init(producer_id[3]) := none;
        init(last_producer_toggle[0]) := FALSE;
    init(last_producer_toggle[1]) := FALSE;
    init(last_producer_toggle[2]) := FALSE;
    init(last_producer_toggle[3]) := FALSE;
    init(last_producer_toggle[4]) := FALSE;
    init(last_producer_toggle[5]) := FALSE;
    init(last_producer_toggle[6]) := FALSE;
    init(last_producer_toggle[7]) := FALSE;
    init(last_producer_toggle[8]) := FALSE;
    init(last_producer_toggle[9]) := FALSE;
        init(last_consumer_toggle[0]) := FALSE;
    init(last_consumer_toggle[1]) := FALSE;
    init(last_consumer_toggle[2]) := FALSE;
    init(last_consumer_toggle[3]) := FALSE;
    init(last_consumer_toggle[4]) := FALSE;
    init(last_consumer_toggle[5]) := FALSE;
    init(last_consumer_toggle[6]) := FALSE;
    init(last_consumer_toggle[7]) := FALSE;
    init(last_consumer_toggle[8]) := FALSE;
    init(last_consumer_toggle[9]) := FALSE;
    init(next_producer_turn) := {0};
    init(next_consumer_turn) := {0,1};

    next(tail) := case
        (producer_toggles[0] != last_producer_toggle[0]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[1] != last_producer_toggle[1]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[2] != last_producer_toggle[2]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[3] != last_producer_toggle[3]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[4] != last_producer_toggle[4]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[5] != last_producer_toggle[5]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[6] != last_producer_toggle[6]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[7] != last_producer_toggle[7]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[8] != last_producer_toggle[8]) : (tail + 1) mod Q_SIZE;
        (producer_toggles[9] != last_producer_toggle[9]) : (tail + 1) mod Q_SIZE;
        TRUE : tail;
    esac;
    next(producer_id[0]) := case
        tail = 0 & producer_toggles[0] != last_producer_toggle[0] : clt0;
        tail = 0 & producer_toggles[1] != last_producer_toggle[1] : clt1;
        tail = 0 & producer_toggles[2] != last_producer_toggle[2] : clt2;
        tail = 0 & producer_toggles[3] != last_producer_toggle[3] : clt3;
        tail = 0 & producer_toggles[4] != last_producer_toggle[4] : clt4;
        tail = 0 & producer_toggles[5] != last_producer_toggle[5] : clt5;
        tail = 0 & producer_toggles[6] != last_producer_toggle[6] : clt6;
        tail = 0 & producer_toggles[7] != last_producer_toggle[7] : clt7;
        tail = 0 & producer_toggles[8] != last_producer_toggle[8] : clt8;
        tail = 0 & producer_toggles[9] != last_producer_toggle[9] : clt9;
        TRUE : producer_id[0];
    esac;
    next(producer_id[1]) := case
        tail = 1 & producer_toggles[0] != last_producer_toggle[0] : clt0;
        tail = 1 & producer_toggles[1] != last_producer_toggle[1] : clt1;
        tail = 1 & producer_toggles[2] != last_producer_toggle[2] : clt2;
        tail = 1 & producer_toggles[3] != last_producer_toggle[3] : clt3;
        tail = 1 & producer_toggles[4] != last_producer_toggle[4] : clt4;
        tail = 1 & producer_toggles[5] != last_producer_toggle[5] : clt5;
        tail = 1 & producer_toggles[6] != last_producer_toggle[6] : clt6;
        tail = 1 & producer_toggles[7] != last_producer_toggle[7] : clt7;
        tail = 1 & producer_toggles[8] != last_producer_toggle[8] : clt8;
        tail = 1 & producer_toggles[9] != last_producer_toggle[9] : clt9;
        TRUE : producer_id[1];
    esac;
    next(producer_id[2]) := case
        tail = 2 & producer_toggles[0] != last_producer_toggle[0] : clt0;
        tail = 2 & producer_toggles[1] != last_producer_toggle[1] : clt1;
        tail = 2 & producer_toggles[2] != last_producer_toggle[2] : clt2;
        tail = 2 & producer_toggles[3] != last_producer_toggle[3] : clt3;
        tail = 2 & producer_toggles[4] != last_producer_toggle[4] : clt4;
        tail = 2 & producer_toggles[5] != last_producer_toggle[5] : clt5;
        tail = 2 & producer_toggles[6] != last_producer_toggle[6] : clt6;
        tail = 2 & producer_toggles[7] != last_producer_toggle[7] : clt7;
        tail = 2 & producer_toggles[8] != last_producer_toggle[8] : clt8;
        tail = 2 & producer_toggles[9] != last_producer_toggle[9] : clt9;
        TRUE : producer_id[2];
    esac;
    next(producer_id[3]) := case
        tail = 3 & producer_toggles[0] != last_producer_toggle[0] : clt0;
        tail = 3 & producer_toggles[1] != last_producer_toggle[1] : clt1;
        tail = 3 & producer_toggles[2] != last_producer_toggle[2] : clt2;
        tail = 3 & producer_toggles[3] != last_producer_toggle[3] : clt3;
        tail = 3 & producer_toggles[4] != last_producer_toggle[4] : clt4;
        tail = 3 & producer_toggles[5] != last_producer_toggle[5] : clt5;
        tail = 3 & producer_toggles[6] != last_producer_toggle[6] : clt6;
        tail = 3 & producer_toggles[7] != last_producer_toggle[7] : clt7;
        tail = 3 & producer_toggles[8] != last_producer_toggle[8] : clt8;
        tail = 3 & producer_toggles[9] != last_producer_toggle[9] : clt9;
        TRUE : producer_id[3];
    esac;

    next(head) := case
        (consumer_toggles[0] != last_consumer_toggle[0]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[1] != last_consumer_toggle[1]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[2] != last_consumer_toggle[2]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[3] != last_consumer_toggle[3]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[4] != last_consumer_toggle[4]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[5] != last_consumer_toggle[5]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[6] != last_consumer_toggle[6]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[7] != last_consumer_toggle[7]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[8] != last_consumer_toggle[8]) : (head + 1) mod Q_SIZE;
        (consumer_toggles[9] != last_consumer_toggle[9]) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

        next(last_producer_toggle[0]) := case
        (producer_toggles[0] != last_producer_toggle[0]) : producer_toggles[0];
        TRUE : last_producer_toggle[0];
    esac;

    next(last_producer_toggle[1]) := case
        (producer_toggles[1] != last_producer_toggle[1]) : producer_toggles[1];
        TRUE : last_producer_toggle[1];
    esac;

    next(last_producer_toggle[2]) := case
        (producer_toggles[2] != last_producer_toggle[2]) : producer_toggles[2];
        TRUE : last_producer_toggle[2];
    esac;

    next(last_producer_toggle[3]) := case
        (producer_toggles[3] != last_producer_toggle[3]) : producer_toggles[3];
        TRUE : last_producer_toggle[3];
    esac;

    next(last_producer_toggle[4]) := case
        (producer_toggles[4] != last_producer_toggle[4]) : producer_toggles[4];
        TRUE : last_producer_toggle[4];
    esac;

    next(last_producer_toggle[5]) := case
        (producer_toggles[5] != last_producer_toggle[5]) : producer_toggles[5];
        TRUE : last_producer_toggle[5];
    esac;

    next(last_producer_toggle[6]) := case
        (producer_toggles[6] != last_producer_toggle[6]) : producer_toggles[6];
        TRUE : last_producer_toggle[6];
    esac;

    next(last_producer_toggle[7]) := case
        (producer_toggles[7] != last_producer_toggle[7]) : producer_toggles[7];
        TRUE : last_producer_toggle[7];
    esac;

    next(last_producer_toggle[8]) := case
        (producer_toggles[8] != last_producer_toggle[8]) : producer_toggles[8];
        TRUE : last_producer_toggle[8];
    esac;

    next(last_producer_toggle[9]) := case
        (producer_toggles[9] != last_producer_toggle[9]) : producer_toggles[9];
        TRUE : last_producer_toggle[9];
    esac;

        next(last_consumer_toggle[0]) := case
        (consumer_toggles[0] != last_consumer_toggle[0]) : consumer_toggles[0];
        TRUE : last_consumer_toggle[0];
    esac;

    next(last_consumer_toggle[1]) := case
        (consumer_toggles[1] != last_consumer_toggle[1]) : consumer_toggles[1];
        TRUE : last_consumer_toggle[1];
    esac;

    next(last_consumer_toggle[2]) := case
        (consumer_toggles[2] != last_consumer_toggle[2]) : consumer_toggles[2];
        TRUE : last_consumer_toggle[2];
    esac;

    next(last_consumer_toggle[3]) := case
        (consumer_toggles[3] != last_consumer_toggle[3]) : consumer_toggles[3];
        TRUE : last_consumer_toggle[3];
    esac;

    next(last_consumer_toggle[4]) := case
        (consumer_toggles[4] != last_consumer_toggle[4]) : consumer_toggles[4];
        TRUE : last_consumer_toggle[4];
    esac;

    next(last_consumer_toggle[5]) := case
        (consumer_toggles[5] != last_consumer_toggle[5]) : consumer_toggles[5];
        TRUE : last_consumer_toggle[5];
    esac;

    next(last_consumer_toggle[6]) := case
        (consumer_toggles[6] != last_consumer_toggle[6]) : consumer_toggles[6];
        TRUE : last_consumer_toggle[6];
    esac;

    next(last_consumer_toggle[7]) := case
        (consumer_toggles[7] != last_consumer_toggle[7]) : consumer_toggles[7];
        TRUE : last_consumer_toggle[7];
    esac;

    next(last_consumer_toggle[8]) := case
        (consumer_toggles[8] != last_consumer_toggle[8]) : consumer_toggles[8];
        TRUE : last_consumer_toggle[8];
    esac;

    next(last_consumer_toggle[9]) := case
        (consumer_toggles[9] != last_consumer_toggle[9]) : consumer_toggles[9];
        TRUE : last_consumer_toggle[9];
    esac;

    next(next_producer_turn) := {0};

    next(next_consumer_turn) := case
        next_consumer_turn = 0 : 1;
        next_consumer_turn = 1 : 0;
        TRUE : next_consumer_turn;
    esac;

DEFINE
    request_consumed := last_consumer_toggle[0] != consumer_toggles[0] | last_consumer_toggle[1] != consumer_toggles[1] | last_consumer_toggle[2] != consumer_toggles[2] | last_consumer_toggle[3] != consumer_toggles[3] | last_consumer_toggle[4] != consumer_toggles[4] | last_consumer_toggle[5] != consumer_toggles[5] | last_consumer_toggle[6] != consumer_toggles[6] | last_consumer_toggle[7] != consumer_toggles[7] | last_consumer_toggle[8] != consumer_toggles[8] | last_consumer_toggle[9] != consumer_toggles[9];
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);


MODULE ClientExtended(request_queue, ack_queue, ack_owners, client_id, client_states)
VAR
    client_request_state : {sending, sent};
    client_ack_state  : {receiving, received};
    request_toggle : boolean;  
    ack_toggle : boolean;    
    ack_received : boolean;
    request_sent : boolean;
    num_requests_sent : 0..100;    

ASSIGN
    init(client_request_state) := sending;
    init(client_ack_state)  := receiving;
    init(request_toggle) := FALSE;
    init(ack_toggle) := FALSE;
    init(ack_received) := TRUE;
    init(request_sent) := FALSE;
    init(num_requests_sent) := 0;

    next(client_request_state) := case
            client_request_state = sending & request_queue.full : sending;
            client_request_state = sending & !request_queue.full & ack_received & request_queue.next_producer_turn = client_id &
            (client_states[0] = TRUE) : sent;
            client_request_state = sent & !request_queue.full : sending;
            client_request_state = sent & request_queue.full : sent;
            TRUE : client_request_state;
        esac;

    next(client_ack_state) := case
            client_ack_state = receiving & ack_queue.empty : receiving;
            client_ack_state = receiving & !ack_queue.empty & request_sent & (ack_owners[0] = self_id | ack_owners[1] = self_id) : received;
            client_ack_state = received & !ack_queue.empty : receiving;
            client_ack_state = received & ack_queue.empty : received;
            TRUE : client_ack_state;
        esac;

    next(request_toggle) := case
        client_request_state = sending & !request_queue.full & ack_received & request_queue.next_producer_turn = client_id &
            (client_states[0] = TRUE) : !request_toggle;              
        TRUE : request_toggle;                                                      
    esac;

    next(ack_toggle) := case
        client_ack_state = receiving & !ack_queue.empty & request_sent & (ack_owners[0] = self_id | ack_owners[1] = self_id) : !ack_toggle;                   
        TRUE : ack_toggle;                                                      
    esac;

    next(ack_received) := case
        client_request_state = sending & !request_queue.full & ack_received & request_queue.next_producer_turn = client_id &
            (client_states[0] = TRUE) : FALSE;       -- false because a new request has just been sent
        client_ack_state = receiving & !ack_queue.empty & request_sent & (ack_owners[0] = self_id | ack_owners[1] = self_id) : TRUE;          -- true because a new ack has been received
        TRUE : ack_received;           
    esac;

    next(request_sent) := case
        client_request_state = sending & !request_queue.full & ack_received & request_queue.next_producer_turn = client_id &
            (client_states[0] = TRUE) : TRUE;
        client_ack_state = receiving & !ack_queue.empty & request_sent & (ack_owners[0] = self_id | ack_owners[1] = self_id) : FALSE;
        TRUE : request_sent;
    esac;
    next(num_requests_sent) := case
        client_request_state = sending & !request_queue.full & ack_received & request_queue.next_producer_turn = client_id &
            (client_states[0] = TRUE) & num_requests_sent < 100 : num_requests_sent + 1;                   
        TRUE : num_requests_sent;                                                    
    esac;
DEFINE
    self_id := case
        client_id = 0 : clt0;
        client_id = 1 : clt1;
        client_id = 2 : clt2;
        client_id = 3 : clt3;
        client_id = 4 : clt4;
        client_id = 5 : clt5;
        client_id = 6 : clt6;
        client_id = 7 : clt7;
        client_id = 8 : clt8;
        client_id = 9 : clt9;
    esac;


MODULE ServerExtended(request_queue, ack_queue, server_id)
VAR
    fault_mode_byzantine : {none, byzantine_state};
    server_request_state : {receiving, received};
    server_ack_state : {sending, sent};
    request_toggle : boolean;  
    ack_toggle : boolean;
    request_received : boolean;
    request_source : {none, clt0, clt1, clt2, clt3, clt4, clt5, clt6, clt7, clt8, clt9};
    pending_ack : boolean;
    ack_consume_marker : boolean;
    num_requests_received : 0..100;

ASSIGN
    init(fault_mode_byzantine) := none;
    init(server_request_state) := receiving;
    init(server_ack_state) := sending;
    init(request_toggle) := FALSE;
    init(ack_toggle) := FALSE;
    init(request_received) := FALSE;
    init(request_source) := none;
    init(pending_ack) := FALSE;
    init(ack_consume_marker) := FALSE;
    init(num_requests_received) := 0;
    next(fault_mode_byzantine) :=
        case
            fault_mode_byzantine = none : {none, byzantine_state};
            TRUE              : fault_mode_byzantine;
        esac;


    next(server_request_state) :=
        case
        fault_mode_byzantine = byzantine_state : {receiving, received};
            server_request_state = receiving & request_queue.empty : receiving;
            server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_consumer_turn = server_id : received;
            server_request_state = received & !request_queue.empty : receiving;
            server_request_state = received & request_queue.empty : received;
            TRUE : server_request_state;
        esac;

    next(server_ack_state) :=
        case
            server_ack_state = sending & ack_queue.full : sending;
            server_ack_state = sending & !ack_queue.full & request_received : sent;
            server_ack_state = sent & !ack_queue.full : sending;
            server_ack_state = sent & ack_queue.full : sent;
            TRUE : server_ack_state;
        esac;

    next(request_toggle) := case
        fault_mode_byzantine = none &
        server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_consumer_turn = server_id : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(ack_toggle) := case
        server_ack_state = sending & !ack_queue.full & request_received : !ack_toggle;                   
        TRUE : ack_toggle;                                                    
    esac;

    next(request_received) := case
        server_ack_state = sending & !ack_queue.full & request_received : FALSE;        -- false because a new ack has just been sent
        server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_consumer_turn = server_id : TRUE;         -- true because a new request has been received
        TRUE : request_received;     
    esac;

    next(request_source) := case
        server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_consumer_turn = server_id : request_queue.producer_id[request_queue.head];
        TRUE : request_source;
    esac;

    next(pending_ack) := case
        server_ack_state = sending & !ack_queue.full & request_received : TRUE;
        pending_ack & (
            (request_source = clt0 & ack_queue.last_consumer_toggle[0] != ack_consume_marker)
        ) : FALSE;
        TRUE : pending_ack;
    esac;

    next(ack_consume_marker) := case
        server_ack_state = sending & !ack_queue.full & request_received & request_source = clt0 : ack_queue.last_consumer_toggle[0];
        TRUE : ack_consume_marker;
    esac;

    next(num_requests_received) := case
        fault_mode_byzantine = none &
        server_request_state = receiving & !request_queue.empty & !pending_ack & !request_queue.request_consumed & request_queue.next_consumer_turn = server_id & num_requests_received < 100 : num_requests_received + 1;                   
        TRUE : num_requests_received;                                                    
    esac;


MODULE Extended()
DEFINE
    Q_SIZE := 4;
VAR
    request_prod_toggles : array 0..9 of boolean;
    request_cons_toggles : array 0..9 of boolean;
    ack_prod_toggles : array 0..9 of boolean;
    ack_cons_toggles : array 0..9 of boolean;

    client_states : array 0..9 of boolean;
    ack_owners : array 0..9 of {none, clt0, clt1, clt2, clt3, clt4, clt5, clt6, clt7, clt8, clt9};
    client1 : ClientExtended(request_queue, ack_queue, ack_owners, 0, client_states);
    server1 : ServerExtended(request_queue, ack_queue, 0);
    server2 : ServerExtended(request_queue, ack_queue, 1);
    request_queue : QueueExtended(Q_SIZE, request_prod_toggles, request_cons_toggles);
    ack_queue : QueueExtended(Q_SIZE, ack_prod_toggles, ack_cons_toggles);
ASSIGN
    request_prod_toggles[0] := client1.request_toggle;
    request_prod_toggles[1] := FALSE;
    request_prod_toggles[2] := FALSE;
    request_prod_toggles[3] := FALSE;
    request_prod_toggles[4] := FALSE;
    request_prod_toggles[5] := FALSE;
    request_prod_toggles[6] := FALSE;
    request_prod_toggles[7] := FALSE;
    request_prod_toggles[8] := FALSE;
    request_prod_toggles[9] := FALSE;
    request_cons_toggles[0] := server1.request_toggle;
    request_cons_toggles[1] := server2.request_toggle;
    request_cons_toggles[2] := FALSE;
    request_cons_toggles[3] := FALSE;
    request_cons_toggles[4] := FALSE;
    request_cons_toggles[5] := FALSE;
    request_cons_toggles[6] := FALSE;
    request_cons_toggles[7] := FALSE;
    request_cons_toggles[8] := FALSE;
    request_cons_toggles[9] := FALSE;
    ack_prod_toggles[0] := server1.ack_toggle;
    ack_prod_toggles[1] := server2.ack_toggle;
    ack_prod_toggles[2] := FALSE;
    ack_prod_toggles[3] := FALSE;
    ack_prod_toggles[4] := FALSE;
    ack_prod_toggles[5] := FALSE;
    ack_prod_toggles[6] := FALSE;
    ack_prod_toggles[7] := FALSE;
    ack_prod_toggles[8] := FALSE;
    ack_prod_toggles[9] := FALSE;
    ack_cons_toggles[0] := client1.ack_toggle;
    ack_cons_toggles[1] := FALSE;
    ack_cons_toggles[2] := FALSE;
    ack_cons_toggles[3] := FALSE;
    ack_cons_toggles[4] := FALSE;
    ack_cons_toggles[5] := FALSE;
    ack_cons_toggles[6] := FALSE;
    ack_cons_toggles[7] := FALSE;
    ack_cons_toggles[8] := FALSE;
    ack_cons_toggles[9] := FALSE;
    client_states[0] := client1.ack_received;
    client_states[1] := TRUE;
    client_states[2] := TRUE;
    client_states[3] := TRUE;
    client_states[4] := TRUE;
    client_states[5] := TRUE;
    client_states[6] := TRUE;
    client_states[7] := TRUE;
    client_states[8] := TRUE;
    client_states[9] := TRUE;
    ack_owners[0] := server1.request_source;
    ack_owners[1] := server2.request_source;
    ack_owners[2] := none;
    ack_owners[3] := none;
    ack_owners[4] := none;
    ack_owners[5] := none;
    ack_owners[6] := none;
    ack_owners[7] := none;
    ack_owners[8] := none;
    ack_owners[9] := none;


MODULE Sync()
VAR
    nominal  : Nominal();
    extended : Extended();


LTLSPEC (
    (extended.request_queue.next_consumer_turn = 1) &

    -- Force extended server1 to stay healthy for steps 1-3
    (extended.server1.fault_mode_byzantine = none & X extended.server1.fault_mode_byzantine = none
    & X X extended.server1.fault_mode_byzantine = none) &

    -- Force extended server2 to stay healthy for steps 1-9
    (extended.server2.fault_mode_byzantine = none & X extended.server2.fault_mode_byzantine = none
    & X X extended.server2.fault_mode_byzantine = none & X X X extended.server2.fault_mode_byzantine = none
    & X X X X extended.server2.fault_mode_byzantine = none & X X X X X extended.server2.fault_mode_byzantine = none
    & X X X X X X extended.server2.fault_mode_byzantine = none & X X X X X X X extended.server2.fault_mode_byzantine = none
    & X X X X X X X X extended.server2.fault_mode_byzantine = none)
) ->
    G(nominal.server.num_requests_received =
    extended.server1.num_requests_received +
    extended.server2.num_requests_received)

MODULE main
VAR
    sync : Sync();