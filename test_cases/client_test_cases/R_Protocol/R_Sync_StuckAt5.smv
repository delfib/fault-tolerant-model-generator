-- =========================================================
-- Queue module
-- =========================================================
MODULE Queue(Q_SIZE, client_toggle, server_toggle)
VAR
    head : 0..3;
    tail : 0..3;
    last_client_toggle : boolean;
    last_server_toggle : boolean;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
    init(last_client_toggle) := FALSE;
    init(last_server_toggle) := FALSE;

    next(tail) := case
        (client_toggle != last_client_toggle) : (tail + 1) mod Q_SIZE; 
        TRUE : tail;
    esac;

    next(head) := case
        (server_toggle != last_server_toggle) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

    next(last_client_toggle) := case
        (client_toggle != last_client_toggle) : client_toggle;
        TRUE : last_client_toggle;
    esac;

    next(last_server_toggle) := case
        (server_toggle != last_server_toggle) : server_toggle;
        TRUE : last_server_toggle;
    esac;

DEFINE
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);



-- =========================================================
-- Client module
-- =========================================================
MODULE Client(queue)
VAR
    client_state : {sending, sent};
    request_toggle : boolean;  
    num_requests_sent : 0..100;         

ASSIGN
    init(client_state) := sending;
    init(request_toggle) := FALSE;
    init(num_requests_sent) := 0;

    next(client_state) :=
        case
            client_state = sending & queue.full : sending;
            client_state = sending & !queue.full : sent;
            client_state = sent & !queue.full : sending;
            client_state = sent & queue.full : sent;
            TRUE : client_state;
        esac;
 
    next(request_toggle) := case
        client_state = sending & !queue.full : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(num_requests_sent) := case
        client_state = sending & !queue.full & num_requests_sent < 100 : num_requests_sent + 1;                   
        TRUE : num_requests_sent;                                                    
    esac;


-- =========================================================
-- Server module
-- =========================================================
MODULE Server(queue)
VAR
    server_state : {receiving, received};
    request_toggle : boolean;  
    num_requests_received : 0..100;
ASSIGN
    init(server_state) := receiving;
    init(request_toggle) := FALSE;
    init(num_requests_received) := 0;

    next(server_state) :=
        case
            server_state = receiving & queue.empty : receiving;
            server_state = receiving & !queue.empty : received;
            server_state = received & !queue.empty : receiving;
            server_state = received & queue.empty : received;
            TRUE : server_state;
        esac;

    next(request_toggle) := case
        server_state = receiving & !queue.empty : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(num_requests_received) := case
        server_state = receiving & !queue.empty & num_requests_received < 100 : num_requests_received + 1;                   
        TRUE : num_requests_received;                                                    
    esac;


-- =========================================================
-- Nominal wrapper
-- =========================================================
MODULE Nominal()
DEFINE
    Q_SIZE := 4;
VAR
    client : Client(queue);
    server : Server(queue);
    queue : Queue(Q_SIZE, client.request_toggle, server.request_toggle);


MODULE QueueExtended(Q_SIZE, client_toggles, server_toggles)
VAR
    head : 0..3;
    tail : 0..3;
    last_client_toggle : array 0..9 of boolean;
    last_server_toggle : array 0..9 of boolean;

    next_client_turn : 0..9;
    next_server_turn : 0..9;

ASSIGN
    init(head) := 0;
    init(tail) := 0;
        init(last_client_toggle[0]) := FALSE;
    init(last_client_toggle[1]) := FALSE;
    init(last_client_toggle[2]) := FALSE;
    init(last_client_toggle[3]) := FALSE;
    init(last_client_toggle[4]) := FALSE;
    init(last_client_toggle[5]) := FALSE;
    init(last_client_toggle[6]) := FALSE;
    init(last_client_toggle[7]) := FALSE;
    init(last_client_toggle[8]) := FALSE;
    init(last_client_toggle[9]) := FALSE;
        init(last_server_toggle[0]) := FALSE;
    init(last_server_toggle[1]) := FALSE;
    init(last_server_toggle[2]) := FALSE;
    init(last_server_toggle[3]) := FALSE;
    init(last_server_toggle[4]) := FALSE;
    init(last_server_toggle[5]) := FALSE;
    init(last_server_toggle[6]) := FALSE;
    init(last_server_toggle[7]) := FALSE;
    init(last_server_toggle[8]) := FALSE;
    init(last_server_toggle[9]) := FALSE;
    init(next_client_turn) := {0,1,2,3,4};
    init(next_server_turn) := {0};

    next(tail) := case
        (client_toggles[0] != last_client_toggle[0]) : (tail + 1) mod Q_SIZE;
        (client_toggles[1] != last_client_toggle[1]) : (tail + 1) mod Q_SIZE;
        (client_toggles[2] != last_client_toggle[2]) : (tail + 1) mod Q_SIZE;
        (client_toggles[3] != last_client_toggle[3]) : (tail + 1) mod Q_SIZE;
        (client_toggles[4] != last_client_toggle[4]) : (tail + 1) mod Q_SIZE;
        (client_toggles[5] != last_client_toggle[5]) : (tail + 1) mod Q_SIZE;
        (client_toggles[6] != last_client_toggle[6]) : (tail + 1) mod Q_SIZE;
        (client_toggles[7] != last_client_toggle[7]) : (tail + 1) mod Q_SIZE;
        (client_toggles[8] != last_client_toggle[8]) : (tail + 1) mod Q_SIZE;
        (client_toggles[9] != last_client_toggle[9]) : (tail + 1) mod Q_SIZE;
        TRUE : tail;
    esac;

    next(head) := case
        (server_toggles[0] != last_server_toggle[0]) : (head + 1) mod Q_SIZE;
        (server_toggles[1] != last_server_toggle[1]) : (head + 1) mod Q_SIZE;
        (server_toggles[2] != last_server_toggle[2]) : (head + 1) mod Q_SIZE;
        (server_toggles[3] != last_server_toggle[3]) : (head + 1) mod Q_SIZE;
        (server_toggles[4] != last_server_toggle[4]) : (head + 1) mod Q_SIZE;
        (server_toggles[5] != last_server_toggle[5]) : (head + 1) mod Q_SIZE;
        (server_toggles[6] != last_server_toggle[6]) : (head + 1) mod Q_SIZE;
        (server_toggles[7] != last_server_toggle[7]) : (head + 1) mod Q_SIZE;
        (server_toggles[8] != last_server_toggle[8]) : (head + 1) mod Q_SIZE;
        (server_toggles[9] != last_server_toggle[9]) : (head + 1) mod Q_SIZE;
        TRUE : head;
    esac;

        next(last_client_toggle[0]) := case
        (client_toggles[0] != last_client_toggle[0]) : client_toggles[0];
        TRUE : last_client_toggle[0];
    esac;

    next(last_client_toggle[1]) := case
        (client_toggles[1] != last_client_toggle[1]) : client_toggles[1];
        TRUE : last_client_toggle[1];
    esac;

    next(last_client_toggle[2]) := case
        (client_toggles[2] != last_client_toggle[2]) : client_toggles[2];
        TRUE : last_client_toggle[2];
    esac;

    next(last_client_toggle[3]) := case
        (client_toggles[3] != last_client_toggle[3]) : client_toggles[3];
        TRUE : last_client_toggle[3];
    esac;

    next(last_client_toggle[4]) := case
        (client_toggles[4] != last_client_toggle[4]) : client_toggles[4];
        TRUE : last_client_toggle[4];
    esac;

    next(last_client_toggle[5]) := case
        (client_toggles[5] != last_client_toggle[5]) : client_toggles[5];
        TRUE : last_client_toggle[5];
    esac;

    next(last_client_toggle[6]) := case
        (client_toggles[6] != last_client_toggle[6]) : client_toggles[6];
        TRUE : last_client_toggle[6];
    esac;

    next(last_client_toggle[7]) := case
        (client_toggles[7] != last_client_toggle[7]) : client_toggles[7];
        TRUE : last_client_toggle[7];
    esac;

    next(last_client_toggle[8]) := case
        (client_toggles[8] != last_client_toggle[8]) : client_toggles[8];
        TRUE : last_client_toggle[8];
    esac;

    next(last_client_toggle[9]) := case
        (client_toggles[9] != last_client_toggle[9]) : client_toggles[9];
        TRUE : last_client_toggle[9];
    esac;

        next(last_server_toggle[0]) := case
        (server_toggles[0] != last_server_toggle[0]) : server_toggles[0];
        TRUE : last_server_toggle[0];
    esac;

    next(last_server_toggle[1]) := case
        (server_toggles[1] != last_server_toggle[1]) : server_toggles[1];
        TRUE : last_server_toggle[1];
    esac;

    next(last_server_toggle[2]) := case
        (server_toggles[2] != last_server_toggle[2]) : server_toggles[2];
        TRUE : last_server_toggle[2];
    esac;

    next(last_server_toggle[3]) := case
        (server_toggles[3] != last_server_toggle[3]) : server_toggles[3];
        TRUE : last_server_toggle[3];
    esac;

    next(last_server_toggle[4]) := case
        (server_toggles[4] != last_server_toggle[4]) : server_toggles[4];
        TRUE : last_server_toggle[4];
    esac;

    next(last_server_toggle[5]) := case
        (server_toggles[5] != last_server_toggle[5]) : server_toggles[5];
        TRUE : last_server_toggle[5];
    esac;

    next(last_server_toggle[6]) := case
        (server_toggles[6] != last_server_toggle[6]) : server_toggles[6];
        TRUE : last_server_toggle[6];
    esac;

    next(last_server_toggle[7]) := case
        (server_toggles[7] != last_server_toggle[7]) : server_toggles[7];
        TRUE : last_server_toggle[7];
    esac;

    next(last_server_toggle[8]) := case
        (server_toggles[8] != last_server_toggle[8]) : server_toggles[8];
        TRUE : last_server_toggle[8];
    esac;

    next(last_server_toggle[9]) := case
        (server_toggles[9] != last_server_toggle[9]) : server_toggles[9];
        TRUE : last_server_toggle[9];
    esac;

    next(next_client_turn) := {0,1,2,3,4};

    next(next_server_turn) := {0};

DEFINE
    request_consumed := last_server_toggle[0] != server_toggles[0] | last_server_toggle[1] != server_toggles[1] | last_server_toggle[2] != server_toggles[2] | last_server_toggle[3] != server_toggles[3] | last_server_toggle[4] != server_toggles[4] | last_server_toggle[5] != server_toggles[5] | last_server_toggle[6] != server_toggles[6] | last_server_toggle[7] != server_toggles[7] | last_server_toggle[8] != server_toggles[8] | last_server_toggle[9] != server_toggles[9];
    full := ((tail + 1) mod Q_SIZE = head);
    empty := (tail = head);



-- =========================================================
-- Client module
-- =========================================================


MODULE ClientExtended(queue, client_id, client_states)
VAR
    fault_mode_stuck_at : {none, stuck_sending, stuck_sent};
    client_state : {sending, sent};
    request_toggle : boolean;  
    num_requests_sent : 0..100;         

ASSIGN
    init(fault_mode_stuck_at) := none;
    init(client_state) := sending;
    init(request_toggle) := FALSE;
    init(num_requests_sent) := 0;
    next(fault_mode_stuck_at) :=
        case
            fault_mode_stuck_at = none : {none, stuck_sending, stuck_sent};
            TRUE              : fault_mode_stuck_at;
        esac;


    next(client_state) :=
        case
        fault_mode_stuck_at = stuck_sent : sent;
        fault_mode_stuck_at = stuck_sending : sending;
            client_state = sending & queue.full : sending;
            client_state = sending & !queue.full & queue.next_client_turn = client_id &
                (client_states[0] = sending & client_states[1] = sending & client_states[2] = sending & client_states[3] = sending & client_states[4] = sending & client_states[5] = sending & client_states[6] = sending & client_states[7] = sending & client_states[8] = sending & client_states[9] = sending) : sent;
            client_state = sent & !queue.full : sending;
            client_state = sent & queue.full : sent;
            TRUE : client_state;
        esac;
 
    next(request_toggle) := case
        fault_mode_stuck_at = none &
        client_state = sending & !queue.full & queue.next_client_turn = client_id &
                (client_states[0] = sending & client_states[1] = sending & client_states[2] = sending & client_states[3] = sending & client_states[4] = sending & client_states[5] = sending & client_states[6] = sending & client_states[7] = sending & client_states[8] = sending & client_states[9] = sending) : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(num_requests_sent) := case
        fault_mode_stuck_at = none &
        client_state = sending & !queue.full & queue.next_client_turn = client_id &
                (client_states[0] = sending & client_states[1] = sending & client_states[2] = sending & client_states[3] = sending & client_states[4] = sending & client_states[5] = sending & client_states[6] = sending & client_states[7] = sending & client_states[8] = sending & client_states[9] = sending) & num_requests_sent < 100 : num_requests_sent + 1;                   
        TRUE : num_requests_sent;                                                    
    esac;


-- =========================================================
-- Server module
-- =========================================================


MODULE ServerExtended(queue, server_id)
VAR
    server_state : {receiving, received};
    request_toggle : boolean;  
    num_requests_received : 0..100;
ASSIGN
    init(server_state) := receiving;
    init(request_toggle) := FALSE;
    init(num_requests_received) := 0;

    next(server_state) :=
        case
            server_state = receiving & queue.empty : receiving;
            server_state = receiving & !queue.empty & !queue.request_consumed & queue.next_server_turn = server_id : received;
            server_state = received & !queue.empty : receiving;
            server_state = received & queue.empty : received;
            TRUE : server_state;
        esac;

    next(request_toggle) := case
        server_state = receiving & !queue.empty & !queue.request_consumed & queue.next_server_turn = server_id : !request_toggle;                   
        TRUE : request_toggle;                                                    
    esac;

    next(num_requests_received) := case
        server_state = receiving & !queue.empty & !queue.request_consumed & queue.next_server_turn = server_id & num_requests_received < 100 : num_requests_received + 1;                   
        TRUE : num_requests_received;                                                    
    esac;


-- =========================================================
-- Nominal wrapper
-- =========================================================


MODULE Extended()
DEFINE
    Q_SIZE := 4;
VAR
    client_toggles : array 0..9 of boolean;
    server_toggles : array 0..9 of boolean;
    client_states : array 0..9 of {sending, sent};
    client1 : ClientExtended(queue, 0, client_states);
    client2 : ClientExtended(queue, 1, client_states);
    client3 : ClientExtended(queue, 2, client_states);
    client4 : ClientExtended(queue, 3, client_states);
    client5 : ClientExtended(queue, 4, client_states);
    server1 : ServerExtended(queue, 0);
    queue : QueueExtended(Q_SIZE, client_toggles, server_toggles);
ASSIGN
    client_toggles[0] := client1.request_toggle;
    client_toggles[1] := client2.request_toggle;
    client_toggles[2] := client3.request_toggle;
    client_toggles[3] := client4.request_toggle;
    client_toggles[4] := client5.request_toggle;
    client_toggles[5] := FALSE;
    client_toggles[6] := FALSE;
    client_toggles[7] := FALSE;
    client_toggles[8] := FALSE;
    client_toggles[9] := FALSE;
    server_toggles[0] := server1.request_toggle;
    server_toggles[1] := FALSE;
    server_toggles[2] := FALSE;
    server_toggles[3] := FALSE;
    server_toggles[4] := FALSE;
    server_toggles[5] := FALSE;
    server_toggles[6] := FALSE;
    server_toggles[7] := FALSE;
    server_toggles[8] := FALSE;
    server_toggles[9] := FALSE;
    client_states[0] := client1.client_state;
    client_states[1] := client2.client_state;
    client_states[2] := client3.client_state;
    client_states[3] := client4.client_state;
    client_states[4] := client5.client_state;
    client_states[5] := sending;
    client_states[6] := sending;
    client_states[7] := sending;
    client_states[8] := sending;
    client_states[9] := sending;


MODULE Sync()
VAR
    nominal  : Nominal();
    extended : Extended();


LTLSPEC (
    (X X extended.queue.next_client_turn = 1 & X X X X extended.queue.next_client_turn = 2
    & X X X X X X extended.queue.next_client_turn = 3 & X X X X X X X X extended.queue.next_client_turn = 4) &

    -- Force client1 to stay healthy for steps 1 and 2
    (extended.client1.fault_mode = none & X extended.client1.fault_mode = none & X X extended.client1.fault_mode != stuck_sent
    & X X X extended.client1.fault_mode != stuck_sent & X X X X extended.client1.fault_mode != stuck_sent) &

    -- Force client2 to stay healthy for steps 1-4
    (extended.client2.fault_mode = none & X extended.client2.fault_mode = none & 
     X X extended.client2.fault_mode = none & X X X extended.client2.fault_mode = none & 
     X X X X extended.client2.fault_mode != stuck_sent) &
     
    -- Force client3 to stay healthy for steps 1-6
    (extended.client3.fault_mode = none & X extended.client3.fault_mode = none & 
     X X extended.client3.fault_mode = none & X X X extended.client3.fault_mode = none &
     X X X X extended.client3.fault_mode = none & X X X X X extended.client3.fault_mode = none 
     & X X X X X Z extended.client3.fault_mode != stuck_sent) &

      -- Force client4 to stay healthy for steps 1-8
    (extended.client4.fault_mode = none & X extended.client4.fault_mode = none & 
     X X extended.client4.fault_mode = none & X X X extended.client4.fault_mode = none &
     X X X X extended.client4.fault_mode = none & X X X X X extended.client4.fault_mode = none
     & X X X X X X extended.client4.fault_mode = none & X X X X X X X extended.client4.fault_mode = none) &

    -- Force client5 to stay healthy for steps 1-10
    (extended.client5.fault_mode = none & X extended.client5.fault_mode = none & 
     X X extended.client5.fault_mode = none & X X X extended.client5.fault_mode = none &
     X X X X extended.client5.fault_mode = none & X X X X X extended.client5.fault_mode = none
     & X X X X X X extended.client5.fault_mode = none & X X X X X X X extended.client5.fault_mode = none
     & X X X X X X X X extended.client5.fault_mode = none & X X X X X X X X X extended.client5.fault_mode = none)
) ->
    G(nominal.client.num_requests_sent =
    extended.client1.num_requests_sent +
    extended.client2.num_requests_sent + 
    extended.client3.num_requests_sent + 
    extended.client4.num_requests_sent + 
    extended.client5.num_requests_sent)

MODULE main
VAR
    sync : Sync();